# Python cache
__pycache__/
*.pyc
*.pyo

# Local environments
.env
.env.local
.env.*.local
frontend/.env.development
frontend/.env.production

# Dependencies and build dirs
node_modules/
frontend/dist/
*.log
.DS_Store
backend.zip
*.zip
# (PNG/image assets are committed — logo etc.)
# *.png  ← removed, was blocking logo.png

# Ignore all subdirectories in backend by default (unwanted pip packages)
backend/*/

# Whitelist project source code subdirectories in backend
!backend/routers/
!backend/services/
!backend/models/
!backend/data/
!backend/scrapers/
!backend/fir_scraper/

# Ignore compiled shared libraries, helper scripts, and vendored dependency files in backend/
backend/*.so
backend/six.py
backend/typing_extensions.py
backend/threadpoolctl.py
backend/test_server.py
get_appsail_logs.js
deploy_appsail.js

# Ignore large raw data files
data_raw/
backend/data/*.npy
backend/data/*.jsonl
backend/data/chunk_metadata.json
!backend/data/sentinal.db

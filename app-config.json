{
  "name": "sentinal-backend",
  "command": "python3 -m uvicorn main:app --host 0.0.0.0 --port 9000 --workers 1",
  "build_path": "backend",
  "stack": "python_3_11",
  "memory": 2048,
  "port": {
    "http": 9000
  },
  "env_variables": {
    "CATALYST_PROJECT_ID": "50170000000065001",
    "CATALYST_QUICKML_KEY": "${CATALYST_QUICKML_KEY}",
